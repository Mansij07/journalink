# TEMPLATE — copy to a real secret, do NOT commit real values.
#
# `kubectl apply -f k8s/` intentionally does NOT apply this file (the `.example`
# extension is skipped by kubectl), so it can't clobber a real secret. Create the
# real secret out-of-band instead:
#
#   kubectl -n journalink create secret generic journalink-secrets \
#     --from-literal=SUPABASE_SERVICE_ROLE_KEY='...' \
#     --from-literal=RESEND_API_KEY='...'
#
# ...or copy this to k8s/secret.yaml (gitignored), fill it in, and apply it alone.
apiVersion: v1
kind: Secret
metadata:
  name: journalink-secrets
  namespace: journalink
type: Opaque
stringData:
  SUPABASE_SERVICE_ROLE_KEY: "REPLACE_ME"
  RESEND_API_KEY: "REPLACE_ME"
